# ─────────────────────────────────────────────────────────────────────────────
# WeaveHacks 4 — environment
# Copy to .env (start.sh does this for you) and fill in keys.
#
# Runtime agents = W&B Inference (OpenAI-compatible) driven by the OpenAI Agents SDK.
# Observability  = W&B Weave (mandatory).  BOTH use your single W&B API key.
# The W&B Inference credits fund the RUNTIME PRODUCT AGENTS — not build tooling.
# ─────────────────────────────────────────────────────────────────────────────

# ── W&B API key (powers BOTH Weave tracing AND W&B Inference) ──
# Get it at https://wandb.ai/authorize
WANDB_API_KEY=

# ── Runtime inference: W&B Inference (OpenAI-compatible) ──
# Which provider product agents use: wandb (default) | openai.
RUNTIME_PROVIDER=wandb
WANDB_INFERENCE_BASE_URL=https://api.inference.wandb.ai/v1
# Model id. Run `pnpm --filter @weavehacks/api models` to list the ids your key can use.
WANDB_INFERENCE_MODEL=zai-org/GLM-5.1
# Optional usage attribution: "entity/project" (sent as the openai-project header).
# Set it if your key belongs to multiple teams, or if W&B asks you to specify a project.
WANDB_PROJECT=

# ── Weave (observability) ──
WEAVE_PROJECT=weavehacks-4

# ── OpenAI (optional fallback — only used if RUNTIME_PROVIDER=openai) ──
OPENAI_API_KEY=

# ── Redis (shared agent state + pub/sub) ──
REDIS_URL=redis://localhost:6379

# ── Web shell → API ──
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WEAVE_PROJECT=weavehacks-4
